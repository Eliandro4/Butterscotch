<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Butterscotch"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnSelectFile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select game.unx / data.win" />

    <TextView
        android:id="@+id/tvSelectedFile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No file selected"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"/>

    <Switch
        android:id="@+id/switchDebug"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable Debug Mode (-D)"
        android:layout_marginBottom="16dp"/>

    <Switch
        android:id="@+id/switchHeadless"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Headless Mode (-h)"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnLaunch"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="LAUNCH GAME"
        android:textStyle="bold"
        android:textSize="18sp"
        android:enabled="false"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnEditGamepad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Edit Gamepad Layout" />

</LinearLayout>
